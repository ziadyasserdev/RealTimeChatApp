{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DbConn": "Server=YOUR_SERVER;Database=YOUR_DATABASE;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "JwtSetting": {
    "SecretKey": "YourSuperSecretJwtKeyAtLeast32CharactersLong",
    "Issuer": "YourApi",
    "Audience": "YourClient",
    "DurationInMinutes": 60
  }
}